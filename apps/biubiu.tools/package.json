{
	"name": "biubiu.tools",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && node scripts/gen-i18n-types.mjs && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && node scripts/gen-i18n-types.mjs && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"pda:balance-radar": "bun src/lib/pda-apps/balance-radar/adapters/cli.ts",
		"build:cli:balance-radar": "bun build --compile --target bun --tsconfig-override tsconfig.cli.json --external better-sqlite3 src/lib/pda-apps/balance-radar/adapters/cli.ts --outfile dist/cli/balance-radar",
		"pda:event-scanner": "bun src/lib/pda-apps/event-scanner/adapters/cli.ts",
		"build:cli:event-scanner": "bun build --compile --target bun --tsconfig-override tsconfig.cli.json --external better-sqlite3 src/lib/pda-apps/event-scanner/adapters/cli.ts --outfile dist/cli/event-scanner"
	},
	"dependencies": {
		"@keystonehq/bc-ur-registry-eth": "^0.22.1",
		"@lucide/svelte": "^0.511.0",
		"@mcp-b/global": "^2.0.9",
		"@ngraveio/bc-ur": "^1.1.13",
		"@noble/hashes": "^2.0.1",
		"@resvg/resvg-wasm": "^2.6.2",
		"@scure/bip39": "^2.0.0",
		"@shazow/whatsabi": "^0.26.0",
		"@shelchin/i18n-sveltekit": "workspace:*",
		"@shelchin/pagekit": "workspace:*",
		"@shelchin/pda": "workspace:*",
		"@shelchin/pda-sveltekit": "workspace:*",
		"@shelchin/proeditor-sveltekit": "workspace:*",
		"@shelchin/seo-sveltekit": "workspace:*",
		"@shelchin/taskhub": "workspace:*",
		"@shelchin/vendor-pool": "workspace:*",
		"satori": "^0.19.1",
		"tlock-js": "^0.9.0",
		"uqr": "^0.1.2",
		"viem": "^2.46.0",
		"walletpair-sdk": "^1.1.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.1",
		"@eslint/js": "^9.39.2",
		"@mcp-b/webmcp-types": "^2.0.5",
		"@noble/curves": "^2.0.1",
		"@playwright/test": "^1.58.0",
		"@shelchin/exe-sveltekit": "workspace:*",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^20",
		"@vitest/browser-playwright": "^4.0.18",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"playwright": "^1.58.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.48.2",
		"svelte-check": "^4.3.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.1",
		"vite": "^7.3.1",
		"vite-plugin-arraybuffer": "^0.1.4",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-node-polyfills": "^0.24.0",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	}
}
