{
    "name": "biubiu.tools",
    "packageManager": "bun@1.3.8",
    "license": "MIT",
    "scripts": {
        "postinstall": "node apps/biubiu.tools/scripts/fix-tlock.mjs",
        "build": "turbo run build",
        "build:biubiu": "turbo run build --filter=biubiu.tools",
        "prebuild:biubiu": "node apps/biubiu.tools/scripts/fix-tlock.mjs",
        "dev:biubiu": "turbo run dev --filter=biubiu.tools",
        "predev:biubiu": "node apps/biubiu.tools/scripts/fix-tlock.mjs",
        "preview:biubiu": "bun run build:biubiu && ./apps/biubiu.tools/dist/biubiu --env-file envs/biubiu.env",
        "pda:balance-radar": "bun apps/biubiu.tools/src/lib/pda-apps/balance-radar/adapters/cli.ts",
        "build:cli:balance-radar": "cd apps/biubiu.tools && bun run build:cli:balance-radar",
        "dev:chat": "cd apps/chat.biubiu.tools && bun run dev",
        "deploy:chat": "cd apps/chat.biubiu.tools && bun run deploy"
    },
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "devDependencies": {
        "turbo": "^2.8.3"
    },
    "dependencies": {
        "@resvg/resvg-wasm": "^2.6.2",
        "walletpair-sdk": "^1.1.0"
    },
    "overrides": {
        "tlock-js": {
            "@noble/hashes": "1.8.0",
            "@noble/curves": "1.9.7"
        },
        "drand-client": {
            "@noble/hashes": "1.8.0"
        }
    }
}